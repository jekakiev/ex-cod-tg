#
# Minimal manual config for ex-cod-tg.
# Most settings are auto-detected during onboarding and can be changed from Telegram.
# Actual runtime config is stored at:
# ~/Library/Application Support/ex-cod-tg/config.env on macOS
# ~/.config/ex-cod-tg/config.env on Linux
#

TELEGRAM_BOT_TOKEN=1234567890:telegram-token
